# AFDM Intake CleanRoom
# Strict clean-room ignore policy
# Track source docs, specs, fixtures, tests, and approved code only.
# Ignore local secrets, caches, generated artifacts, logs, traces, media, zips, and backup files.

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment and secrets
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
*.jks
*.keystore
secrets/
credentials/
auth.json
token.json

# OS junk
.DS_Store
Thumbs.db
Desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.tmp
*.temp

# Python, if any tooling gets added
__pycache__/
*.pyc
.venv/
venv/

# Test coverage and reports
coverage/
.nyc_output/
test-results/
playwright-report/
reports/
report/
junit.xml
*.lcov

# Playwright and browser-run artifacts
blob-report/
artifacts/
downloads/
screenshots/
videos/
traces/
trace/
*.zip
*.trace
*.har
*.webm
*.png
*.jpg
*.jpeg
*.mp4

# Logs
logs/
*.log

# Generated manifests and machine output, keep local by default unless explicitly approved
generated/
tmp/
temp/
out/
dist/
build/

# Intake internal artifacts, local by default
*.bak
*.orig
*.rej

# Do not ignore the governed repo source folders
!spec/
!docs/
!docs/source-locks/
!tests/
!fixtures/
!src/
!agents/